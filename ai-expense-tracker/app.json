{
  "expo": {
    "name": "ai-expense-tracker",
    "slug": "ai-expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "hermesEnabled": true,
    "splash": {
      "image": "./assets/splash_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kdd.aiexpensetracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive_icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "86f05f99-8472-475e-a017-c45a019db4fa"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "abiFilters": [
              "arm64-v8a",
              "x86_64"
            ]
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/new_astro/new_astro_medium.otf",
            "./assets/fonts/neue_haas_grotesk/neue_haas_grotesk_medium.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "new_astro",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/new_astro/new_astro_medium.otf",
                    "weight": 400
                  }
                ]
              }
            ]
          }
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/icons/google.png"
          ]
        }
      ]
    ]
  }
}
